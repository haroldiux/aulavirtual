APP_NAME="Aula Virtual UNITEPC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:9000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Dentro de Docker usar DB_HOST=mysql; en local con XAMPP usar 127.0.0.1
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=aula_virtual
DB_USERNAME=aula
DB_PASSWORD=aula_secret

# Sin Redis en el compose de 3 contenedores: usamos database/sync como fallback.
# Para reactivar Redis, agregar el servicio al compose y volver a redis en estas 3 vars.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

# Redis (opcional, requiere servicio redis en el compose)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@unitepc.edu"
MAIL_FROM_NAME="${APP_NAME}"

# MinIO / S3-compatible
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=aula-virtual
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000

# SSO SISA (stub local). Setear SISA_STUB_ENABLED=false y proveer URL+TOKEN para usar el SSO real.
SISA_API_URL=
SISA_API_TOKEN=
SISA_STUB_ENABLED=true

# Sanctum SPA
SANCTUM_STATEFUL_DOMAINS=localhost:9000,localhost:8000,127.0.0.1:9000

VITE_API_URL="http://localhost:8000/api"